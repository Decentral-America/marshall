{
  "name": "@decentralchain/marshall",
  "version": "1.0.0",
  "description": "Official binary serialization and data marshalling library for the DecentralChain blockchain — converts transactions and DEX orders between JavaScript objects, binary wire format, and JSON with safe 64-bit integer handling",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "serialization",
    "deserialization",
    "marshalling",
    "binary",
    "parser",
    "transactions",
    "dex",
    "smart-contracts",
    "typescript",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/marshall.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/marshall#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/marshall/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:publint": "publint",
    "check:exports": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "prepare": "lefthook install",
    "prepack": "npm run build",
    "postversion": "npm publish",
    "postpublish": "git push",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "size-limit": [
    {
      "path": "./dist/index.mjs",
      "limit": "11 kB"
    }
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "dependencies": {
    "base64-js": "^1.3.0",
    "long": "^5.3.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@evilmartians/lefthook": "^1.11.0",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "bignumber.js": "^10.0.2",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
